---
---

<header class="float-nav" id="floatNav" aria-hidden="true">
  <div class="float-nav-inner">
    <a href="/" class="float-nav-logo">
      <img src="/assets/logo.svg" alt="Axe Motion Automation" width="140" />
    </a>
    <nav class="float-nav-links" aria-label="Site navigation">
      <a href="#services" data-i18n="nav.services">Services</a>
      <a href="#about"    data-i18n="nav.about">About</a>
      <a href="#contact"  data-i18n="nav.contact">Contact</a>
    </nav>
    <a href="#contact" class="btn btn-hero-primary float-nav-cta" data-i18n="nav.contact">Contact</a>

    <!-- Hamburger (mobile) -->
    <button class="burger" id="burger" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobileMenu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile fullscreen menu -->
<div class="mobile-menu" id="mobileMenu" role="dialog" aria-label="Navigation menu" aria-modal="true" hidden>
  <div class="mobile-menu-bg"></div>
  <nav class="mobile-menu-links">
    <a href="#services" data-i18n="nav.services" style="animation-delay:0.04s">Services</a>
    <a href="#about"    data-i18n="nav.about"    style="animation-delay:0.09s">About</a>
    <a href="#contact"  data-i18n="nav.contact"  style="animation-delay:0.14s">Contact</a>
  </nav>
  <div class="mobile-menu-lang">
    <button data-lang-btn="en"   aria-pressed="true">🇺🇸 EN</button>
    <button data-lang-btn="pt-BR" aria-pressed="false">🇧🇷 PT</button>
  </div>
</div>

<style>
  .float-nav {
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(-100%);
    width: calc(100% - 80px);
    max-width: 760px;
    z-index: 100;
    opacity: 0;
    transition: opacity 0.15s var(--ease-out), transform 0.35s var(--ease-out);
    pointer-events: none;
  }

  .float-nav.is-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: all;
  }

  .float-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: rgba(13,27,42,0.82);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 14px 28px;
  }

  .float-nav-logo img { display: block; filter: brightness(10); opacity: 0.9; }

  .float-nav-links { display: flex; gap: 28px; align-items: center; }
  .float-nav-links a {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255,255,255,0.5); transition: color 0.2s;
  }
  .float-nav-links a:hover { color: rgba(255,255,255,0.9); }

  .btn-hero-primary {
    background: var(--blue);
    color: var(--white);
    border: 1.5px solid var(--blue);
    padding: 10px 20px;
    border-radius: 8px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.22s var(--ease-out);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }
  .btn-hero-primary:hover {
    background: var(--blue-bright);
    border-color: var(--blue-bright);
    box-shadow: 0 0 0 4px rgba(28,110,232,0.2), 0 10px 28px rgba(28,110,232,0.35);
    transform: translateY(-1px);
  }

  .float-nav-cta { }

  /* Burger */
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .burger span {
    display: block; width: 22px; height: 2px;
    background: rgba(255,255,255,0.7);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }
  .burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu */
  .mobile-menu {
    position: fixed; inset: 0; z-index: 99;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    gap: 40px;
  }
  .mobile-menu[hidden] { display: none; }

  .mobile-menu-bg {
    position: absolute; inset: 0;
    background: rgba(9,18,30,0.97);
    backdrop-filter: blur(40px) saturate(160%);
  }

  .mobile-menu-links {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; align-items: center; gap: 8px;
  }

  .mobile-menu-links a {
    font-size: 32px; font-weight: 800; color: var(--white);
    letter-spacing: -0.5px; padding: 12px 24px;
    opacity: 0; transform: translateY(16px);
    animation: none;
    transition: color 0.2s;
  }
  .mobile-menu-links a:hover { color: var(--blue); }
  .mobile-menu.open .mobile-menu-links a {
    animation: menuLinkIn 0.35s var(--ease-out) both;
  }

  @keyframes menuLinkIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .mobile-menu-lang {
    position: relative; z-index: 1;
    display: flex; gap: 8px;
  }
  .mobile-menu-lang button {
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px; padding: 10px 20px;
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.6); cursor: pointer; transition: background 0.2s, color 0.2s;
  }
  .mobile-menu-lang button.is-active,
  .mobile-menu-lang button:hover { background: rgba(255,255,255,0.16); color: var(--white); }

  @media (max-width: 767px) {
    .float-nav-links, .float-nav-cta { display: none; }
    .burger { display: flex; }
  }
</style>

<script>
  const floatNav = document.getElementById('floatNav')!;
  const hero = document.getElementById('hero')!;
  const burger = document.getElementById('burger')!;
  const mobileMenu = document.getElementById('mobileMenu')!;

  // Show/hide floating nav based on hero visibility
  const io = new IntersectionObserver(
    (entries) => {
      const heroVisible = entries[0].isIntersecting;
      floatNav.classList.toggle('is-visible', !heroVisible);
      floatNav.setAttribute('aria-hidden', heroVisible ? 'true' : 'false');
    },
    { threshold: 0.08 }
  );
  io.observe(hero);

  // Mobile menu toggle
  burger.addEventListener('click', () => {
    const isOpen = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', (!isOpen).toString());
    if (isOpen) {
      mobileMenu.classList.remove('open');
      setTimeout(() => { mobileMenu.hidden = true; }, 300);
      document.body.style.overflow = '';
    } else {
      mobileMenu.hidden = false;
      requestAnimationFrame(() => mobileMenu.classList.add('open'));
      document.body.style.overflow = 'hidden';
    }
  });

  // Close on link click
  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      burger.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.remove('open');
      setTimeout(() => { mobileMenu.hidden = true; }, 300);
      document.body.style.overflow = '';
    });
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu.hidden) {
      burger.setAttribute('aria-expanded', 'false');
      mobileMenu.classList.remove('open');
      setTimeout(() => { mobileMenu.hidden = true; }, 300);
      document.body.style.overflow = '';
    }
  });
</script>
