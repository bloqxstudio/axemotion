---
const specialists = [
  {
    roleKey: 'qc.edson_role', role: 'PLC Specialist',
    descKey: 'qc.edson_desc', desc: 'PLCs, control & SCADA',
  },
  {
    roleKey: 'qc.pedro_role', role: 'Robot Specialist',
    descKey: 'qc.pedro_desc', desc: 'Robotics & integration',
  },
];
---

<!-- FAB Button -->
<button class="qc-fab" id="qcFab" aria-expanded="false" aria-controls="qcModal" aria-label="Contact Us">
  <svg class="qc-fab-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
  </svg>
  <span class="qc-fab-label" data-i18n="qc.fab_label">Contact Us</span>
</button>

<!-- Modal -->
<div class="qc-modal" id="qcModal" role="dialog" aria-label="Quick Contact" aria-modal="true" hidden>
  <div class="qc-header">
    <span class="qc-header-dot"></span>
    <span class="qc-header-title" data-i18n="qc.header_title">Quick Contact</span>
  </div>
  <div class="qc-body">
    <p class="qc-section-label" data-i18n="qc.section_label">Talk to a specialist</p>
    {specialists.map(sp => (
      <div class="qc-person">
        <div class="qc-person-info">
          <p class="qc-person-role" data-i18n={sp.roleKey}>{sp.role}</p>
          <p class="qc-person-desc" data-i18n={sp.descKey}>{sp.desc}</p>
        </div>
      </div>
    ))}
    <div class="qc-divider"></div>
    <a href="#contact" class="qc-form-link" id="qcFormLink">
      <span data-i18n="qc.form_label">Send a Message</span>
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M2.5 7H11.5M11.5 7L7.5 3M11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</div>

<!-- Backdrop -->
<div class="qc-backdrop" id="qcBackdrop" hidden></div>

<style>
  .qc-fab {
    position: fixed;
    bottom: 32px; right: 32px;
    z-index: 102;
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--blue);
    color: var(--white);
    border: 1.5px solid var(--blue);
    border-radius: 8px;
    padding: 15px 32px;
    font-family: var(--font); font-size: 14px; font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    transition: all 0.22s var(--ease-out);
  }
  .qc-fab:hover {
    background: var(--blue-bright);
    border-color: var(--blue-bright);
    box-shadow: 0 0 0 4px rgba(28,110,232,0.2), 0 10px 28px rgba(28,110,232,0.35);
    transform: translateY(-1px);
  }
  .qc-fab-icon { transition: transform 0.25s var(--ease-out); flex-shrink: 0; }
  .qc-fab[aria-expanded="true"] .qc-fab-icon { transform: rotate(45deg); }

  .qc-modal {
    position: fixed;
    bottom: 96px; right: 32px;
    z-index: 103;
    width: 360px;
    background: var(--white);
    border-radius: 16px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.18);
    overflow: hidden;
    transform: translateY(16px);
    opacity: 0;
    transition: opacity 0.28s var(--ease-out), transform 0.28s var(--ease-out);
    pointer-events: none;
  }
  .qc-modal:not([hidden]) { display: block; }
  .qc-modal.open { opacity: 1; transform: translateY(0); pointer-events: all; }

  .qc-header {
    background: var(--navy);
    display: flex; align-items: center; gap: 10px;
    padding: 16px 20px;
  }

  .qc-header-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--blue-bright);
    box-shadow: 0 0 8px var(--blue-bright);
    animation: dotPulse 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 0.7; }
    50%       { opacity: 1; box-shadow: 0 0 14px var(--blue-bright); }
  }

  .qc-header-title {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.7);
  }

  .qc-body { padding: 20px; display: flex; flex-direction: column; gap: 12px; }

  .qc-section-label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--gray-dark); margin-bottom: 4px;
  }

  .qc-person {
    background: var(--gray-light); border-radius: 10px;
    padding: 16px; display: flex; flex-direction: column; gap: 6px;
  }

  .qc-person-role {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--navy); font-weight: 700;
  }

  .qc-person-desc {
    font-size: 12px; color: var(--gray-dark); font-weight: 500;
  }

  .qc-divider { height: 1px; background: var(--gray-card); margin: 4px 0; }

  .qc-form-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; border-radius: 10px;
    font-size: 14px; font-weight: 700; color: var(--navy);
    background: var(--gray-light);
    transition: background 0.2s;
  }
  .qc-form-link:hover { background: var(--gray-card); }
  .qc-form-link svg { transition: transform 0.2s; }
  .qc-form-link:hover svg { transform: translateX(3px); }

  .qc-backdrop {
    position: fixed; inset: 0; z-index: 101;
    background: rgba(9, 18, 30, 0);
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    transition: background 0.28s var(--ease-out), backdrop-filter 0.28s var(--ease-out);
  }
  .qc-backdrop:not([hidden]) { display: block; }
  .qc-backdrop.open {
    background: rgba(9, 18, 30, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  @media (max-width: 767px) {
    .qc-modal { width: calc(100vw - 32px); right: 16px; bottom: 76px; max-height: 60vh; overflow-y: auto; }
    .qc-fab { right: 16px; bottom: 16px; padding: 14px; border-radius: 50%; }
    .qc-fab-label { display: none; }
    .qc-header { padding: 12px 16px; }
    .qc-body { padding: 14px; gap: 8px; }
    .qc-person { padding: 12px 14px; }
    .qc-form-link { padding: 10px 14px; }
  }
</style>

<script>
  const fab      = document.getElementById('qcFab')!;
  const modal    = document.getElementById('qcModal')!;
  const backdrop = document.getElementById('qcBackdrop')!;
  const formLink = document.getElementById('qcFormLink')!;

  function openModal() {
    modal.hidden = false;
    backdrop.hidden = false;
    requestAnimationFrame(() => {
      modal.classList.add('open');
      backdrop.classList.add('open');
    });
    fab.setAttribute('aria-expanded', 'true');
  }

  function closeModal() {
    modal.classList.remove('open');
    backdrop.classList.remove('open');
    fab.setAttribute('aria-expanded', 'false');
    setTimeout(() => {
      modal.hidden = true;
      backdrop.hidden = true;
    }, 280);
  }

  fab.addEventListener('click', () => {
    fab.getAttribute('aria-expanded') === 'true' ? closeModal() : openModal();
  });

  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  formLink.addEventListener('click', (e) => {
    e.preventDefault();
    closeModal();
    setTimeout(() => {
      document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 160);
  });

</script>
