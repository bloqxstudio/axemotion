        'contact.form_success': '✓ Message sent! We\'ll be in touch soon.',
        'contact.form_error':   '✗ Something went wrong. Please try again.',
        'contact.form_sending': '...',
      },
      'pt-BR': {
        'meta.title':'Axe Motion Automation – Excelência em Integração de Sistemas e Automação Industrial',
        'meta.description':'A Axe Motion Automation é especialista em integração de sistemas e software de controle para a indústria no Brasil, Alemanha, EUA e Argentina.',
        'aria.site_nav':'Navegação do site','aria.nav_dialog':'Menu de navegação',
        'aria.burger_label':'Abrir menu','aria.qc_dialog':'Contato Rápido',
        'alt.logo':'Axe Motion Automation','alt.footer_logo':'Axe Motion Automation',
        'alt.carousel_system':'Instalação de automação industrial','alt.carousel_robot':'Robô industrial',
        'alt.carousel_control':'Painel de controle','alt.carousel_circuit':'Placa de circuito',
        'alt.carousel_welding':'Robô industrial de soldagem','alt.carousel_production':'Linha de produção fabril',
        'alt.carousel_sensors':'Tecnologia de sensores','alt.image_break':'Placa de circuito industrial — construída para complexidade',
